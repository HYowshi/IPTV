{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Phim.tv",
  "version": "1.1.0",
  "identifier": "com.phimtv.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Phim.tv - Giải Trí Đa Phương Tiện",
        "width": 1280,
        "height": 720,
        "minWidth": 800,
        "minHeight": 600,
        "center": true,
        "fullscreen": false,
        "resizable": true,
        "visible": true,
        "useHttpsScheme": false
      }
    ],
    "security": {
      "csp": "default-src 'self' 'unsafe-inline' 'unsafe-eval' data: blob: https://* http://*;"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "PhimTV Admin",
    "copyright": "Copyright © 2026 Phim.tv. All rights reserved.",
    "shortDescription": "Ứng dụng xem phim và truyền hình trực tuyến chuẩn TVBox",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Phim.tv",
  "version": "0.2.2",
  "identifier": "com.phimtv.phimtvapp",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Phim.tv - Giải Trí Đa Phương Tiện",
        "width": 1280,
        "height": 720,
        "minWidth": 800,
        "minHeight": 600,
        "center": true,
        "fullscreen": false,
        "resizable": true,
        "visible": true,
        "useHttpsScheme": false
      }
    ],
    "security": {
      "csp": "default-src 'self' 'unsafe-inline' 'unsafe-eval' data: blob: https://* http://*;"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "PhimTV Admin",
    "copyright": "Copyright © 2026 Phim.tv. All rights reserved.",
    "shortDescription": "Ứng dụng xem phim và truyền hình trực tuyến chuẩn TVBox",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "headerImage": "nsis/header.bmp",
        "sidebarImage": "nsis/sidebar.bmp"
      }
    },
    "category": "Entertainment",
    "longDescription": "Phim.tv là ứng dụng giải trí đa phương tiện hỗ trợ xem phim trực tuyến và truyền hình IPTV với chất lượng cao, giao diện đẹp mắt và trải nghiệm mượt mà trên mọi thiết bị."
  }
}
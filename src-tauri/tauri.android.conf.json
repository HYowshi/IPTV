{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Phim.tv",
  "version": "1.1.0",
  "identifier": "com.phimtv.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Phim.tv - Giai Tri Da Phuong Tien",
        "width": 360,
        "height": 640,
        "fullscreen": true,
        "resizable": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": "default-src 'self' 'unsafe-inline' 'unsafe-eval' data: blob: https://* http://*; media-src https://* http://* blob:; connect-src https://* http://* ws://* wss://*;"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "android": {
      "minSdkVersion": 24
    }
  }
}
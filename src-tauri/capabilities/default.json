{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "core:window:allow-set-focus",
    "opener:default",
    "store:default",
    "http:default",
    {
      "identifier": "http:default",
      "allow": [
        {"url": "http://**"},
        {"url": "https://**"}
      ]
    }
  ]
}